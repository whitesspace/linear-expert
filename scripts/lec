  if (!flags.id) fail('--id required', 2);
  const body = { workspaceId, id: flags.id, name: flags.title ?? undefined, description: flags.description, status: flags.status ?? null };
  const r = await httpJson({ baseUrl, path: '/internal/linear/initiatives/update', secret, body, verbose: flags.verbose });
  if (flags.json) return outJson(r);
  return outPlain([JSON.stringify(r)]);
}

