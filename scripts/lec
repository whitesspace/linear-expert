#!/usr/bin/env node
/**
 * lec - Linear Expert CLI (thin wrapper over linear-expert worker internal routes)
 */

import { dispatchCommand, HELP_LINES } from "./lec-lib/commands.mjs";
import { outPlain } from "./lec-lib/runtime.mjs";

const { argv } = process;

function parseArgs(args) {
  const out = { _: [] };
  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (!arg.startsWith("-")) {
      out._.push(arg);
      continue;
    }

    if (arg === "--json") out.json = true;
    else if (arg === "--plain") out.plain = true;
    else if (arg === "--dry-run") out.dryRun = true;
    else if (arg === "-v" || arg === "--verbose") out.verbose = true;
    else if (arg === "-q" || arg === "--quiet") out.quiet = true;
    else if (arg === "-h" || arg === "--help") out.help = true;
    else if (arg === "--version") out.version = true;
    else if (arg === "--team") out.team = args[++i];
    else if (arg === "--workspace") out.workspace = args[++i];
    else if (arg === "--project") out.project = args[++i];
    else if (arg === "--issue") out.issue = args[++i];
    else if (arg === "--initiative") out.initiative = args[++i];
    else if (arg === "--customer") out.customer = args[++i];
    else if (arg === "--query") out.query = args[++i];
    else if (arg === "--label") out.label = args[++i];
    else if (arg === "--id") out.id = args[++i];
    else if (arg === "--title") out.title = args[++i];
    else if (arg === "--status") out.status = args[++i];
    else if (arg === "--state") out.state = args[++i];
    else if (arg === "--state-name") out.stateName = args[++i];
    else if (arg === "--description") out.description = args[++i];
    else if (arg === "--body") out.body = args[++i];
    else if (arg === "--assignee") out.assignee = args[++i];
    else if (arg === "--url") out.url = args[++i];
    else if (arg === "--color") out.color = args[++i];
    else if (arg === "--relation") out.relation = args[++i];
    else if (arg === "--target") out.target = args[++i];
    else if (arg === "--limit") out.limit = Number(args[++i]);
    else if (arg === "--starts-at") out.startsAt = args[++i];
    else if (arg === "--ends-at") out.endsAt = args[++i];
    else if (arg === "--revenue") out.revenue = Number(args[++i]);
    else if (arg === "--size") out.size = Number(args[++i]);
    else if (arg === "--position") out.position = Number(args[++i]);
    else if (arg === "--exclude-done") out.excludeDone = true;
    else if (arg === "--exclude-cancelled") out.excludeCancelled = true;
    else if (arg === "--domain") (out.domains ??= []).push(args[++i]);
    else (out.unknown ??= []).push(arg);
  }
  return out;
}

async function main() {
  const flags = parseArgs(argv.slice(2));
  if (flags.version) {
    outPlain(["0.0.1"]);
    return;
  }
  if (flags.help || flags._.length === 0) {
    outPlain(HELP_LINES);
    return;
  }
  if (flags.unknown?.length) {
    throw new Error(`Unknown flags: ${flags.unknown.join(", ")}`);
  }
  await dispatchCommand(flags._, flags);
}

main().catch((error) => {
  process.stderr.write(`${error?.body ? JSON.stringify(error.body) : error?.message || String(error)}\n`);
  process.exit(error?.status || 1);
});
