}

async function cmdRelationAdd(flags) {
  const baseUrl = env.LEC_BASE_URL || 'https://linear-expert.placeapp.workers.dev';
  const secret = env.OPENCLAW_INTERNAL_SECRET;
  const teamKey = flags.team || 'WS';
  const { workspaceId } = await resolveTeam(teamKey, flags.workspace, flags.verbose);
  if (!flags.issue || !flags.relation || !flags.target) fail('--issue --relation --target required', 2);
  const issueId = await resolveIssueId({ teamKey, issue: flags.issue, workspaceId, secret, baseUrl, verbose: flags.verbose });
  const relatedIssueId = await resolveIssueId({ teamKey, issue: flags.target, workspaceId, secret, baseUrl, verbose: flags.verbose });
  const r = await httpJson({ baseUrl, path: '/internal/linear/issues/relation', secret, body: { workspaceId, issueId, relatedIssueId, relationType: flags.relation }, verbose: flags.verbose });
  if (flags.json) outJson(r); else outPlain(['related']);
}

