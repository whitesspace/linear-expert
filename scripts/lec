async function cmdProjectDelete(flags) {
  const baseUrl = env.LEC_BASE_URL || 'https://linear-expert.placeapp.workers.dev';
  const secret = env.OPENCLAW_INTERNAL_SECRET;
  const teamKey = flags.team || 'WS';
  const { workspaceId } = await resolveTeam(teamKey, flags.workspace, flags.verbose);
  if (!flags.project) fail('--project required', 2);
  const r = await httpJson({ baseUrl, path: '/internal/linear/projects/delete', secret, body: { workspaceId, projectId: flags.project }, verbose: flags.verbose });
  if (flags.json) outJson(r); else outPlain([JSON.stringify(r)]);
}

async function main() {
  const flags = parseArgs(argv.slice(2));
  if (flags.help) return help();
  if (flags.version) return outPlain(['lec 0.2.0']);
  if (flags.unknown?.length) fail(`Unknown flags: ${flags.unknown.join(', ')}`, 2);

  const cmd = flags._[0];
  const sub = flags._[1];
  if (!cmd) { help(); exit(2); }

  try {
    if (cmd === 'auth' && sub === 'status') return await cmdAuthStatus(flags);
    if (cmd === 'bootstrap' && sub === 'project-crud-issues') return await cmdBootstrapProjectCrud(flags);

    if (cmd === 'issue') {
      if (sub === 'create') return await cmdIssueCreate(flags);
      if (sub === 'get') return await cmdIssueGet(flags);
      if (sub === 'update') return await cmdIssueUpdate(flags);
      if (sub === 'assign') return await cmdIssueAssign(flags);
      if (sub === 'state') return await cmdIssueState(flags);
      if (sub === 'add-to-project') return await cmdIssueAddToProject(flags);
    }

    if (cmd === 'comment' && sub === 'create') return await cmdCommentCreate(flags);
    if (cmd === 'attachment' && sub === 'add') return await cmdAttachmentAdd(flags);
    if (cmd === 'relation' && sub === 'add') return await cmdRelationAdd(flags);

    if (cmd === 'project') {
      if (sub === 'list') return await cmdProjectList(flags);
      if (sub === 'get') return await cmdProjectGet(flags);
      if (sub === 'create') return await cmdProjectCreate(flags);
      if (sub === 'update') return await cmdProjectUpdate(flags);
      if (sub === 'delete') return await cmdProjectDelete(flags);
    }

    if (cmd === 'team') {
      if (sub === 'states') return await cmdTeamStates(flags);
    }

    if (cmd === 'triage') {
      if (sub === 'list') return await cmdTriageList(flags);
    }

    if (cmd === 'initiatives') {
      if (sub === 'list') return await cmdInitiativesList(flags);
      if (sub === 'get') return await cmdInitiativesGet(flags);
      if (sub === 'create') return await cmdInitiativesCreate(flags);
      if (sub === 'update') return await cmdInitiativesUpdate(flags);
      if (sub === 'archive') return await cmdInitiativesArchive(flags);
    }

    fail(`Unknown command: ${flags._.join(' ')}`, 2);
  } catch (e) {
    const msg = e?.body ? `${e.message}\n${JSON.stringify(e.body, null, 2)}` : (e?.stack || String(e));
    stderr.write(msg + '\n');
    exit(1);
  }
}

main();

async function cmdTriageList(flags) {
  const baseUrl = env.LEC_BASE_URL || 'https://linear-expert.placeapp.workers.dev';
  const secret = env.OPENCLAW_INTERNAL_SECRET;
  const teamKey = flags.team || 'WS';
  const { workspaceId, teamId } = await resolveTeam(teamKey, flags.workspace, flags.verbose);

  const body = {
    workspaceId,
    teamId,
    stateName: flags.state || 'Triage',
    limit: Number.isFinite(flags.limit) ? flags.limit : 25,
    excludeDone: flags.excludeDone ?? true,
    excludeCancelled: flags.excludeCancelled ?? true,
  };

  const r = await httpJson({ baseUrl, path: '/internal/linear/triage/list', secret, body, verbose: flags.verbose });
  if (flags.json) return outJson(r);

  const issues = r?.result?.issues ?? [];
  if (flags.plain) {
    return outPlain(issues.map((i) => `${i.identifier} ${i.title}`));
  }
  return outPlain([
    `count=${issues.length}`,
    ...issues.map((i) => `- ${i.identifier} ${i.title} [${i.state?.name ?? ''}]`),
  ]);
}

async function cmdInitiativesList(flags) {
  const baseUrl = env.LEC_BASE_URL || 'https://linear-expert.placeapp.workers.dev';
  const secret = env.OPENCLAW_INTERNAL_SECRET;
  const teamKey = flags.team || 'WS';
  const { workspaceId } = await resolveTeam(teamKey, flags.workspace, flags.verbose);
  const body = { workspaceId, limit: Number.isFinite(flags.limit) ? flags.limit : 25 };
  const r = await httpJson({ baseUrl, path: '/internal/linear/initiatives/list', secret, body, verbose: flags.verbose });
  if (flags.json) return outJson(r);
  const items = r?.result?.initiatives ?? [];
  if (flags.plain) return outPlain(items.map((i) => `${i.id} ${i.name}`));
  return outPlain([`count=${items.length}`, ...items.map((i) => `- ${i.name} (${i.status ?? ''})`)]);
}

async function cmdInitiativesGet(flags) {
  const baseUrl = env.LEC_BASE_URL || 'https://linear-expert.placeapp.workers.dev';
  const secret = env.OPENCLAW_INTERNAL_SECRET;
  const teamKey = flags.team || 'WS';
  const { workspaceId } = await resolveTeam(teamKey, flags.workspace, flags.verbose);
  if (!flags.id) fail('--id required', 2);
  const r = await httpJson({ baseUrl, path: '/internal/linear/initiatives/get', secret, body: { workspaceId, id: flags.id }, verbose: flags.verbose });
  if (flags.json) return outJson(r);
  const i = r?.result?.initiative;
  return outPlain(i ? [`${i.name}`, `status=${i.status}`, `url=${i.url || ''}`] : ['null']);
}

async function cmdInitiativesCreate(flags) {
  const baseUrl = env.LEC_BASE_URL || 'https://linear-expert.placeapp.workers.dev';
  const secret = env.OPENCLAW_INTERNAL_SECRET;
  const teamKey = flags.team || 'WS';
  const { workspaceId } = await resolveTeam(teamKey, flags.workspace, flags.verbose);
  if (!flags.title) fail('--title required (initiative name)', 2);
  const body = { workspaceId, name: flags.title, description: flags.description ?? null, status: flags.status ?? null };
  const r = await httpJson({ baseUrl, path: '/internal/linear/initiatives/create', secret, body, verbose: flags.verbose });
  if (flags.json) return outJson(r);
  return outPlain([JSON.stringify(r)]);
}

